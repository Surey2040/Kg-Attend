PORT="4000"
NODE_ENV="development"

DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host:5432/db?sslmode=require"
REDIS_URL="redis://localhost:6379"

JWT_ACCESS_SECRET="your_access_secret_here"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="your_refresh_secret_here"
JWT_REFRESH_TTL_SECONDS=604800

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

QR_HMAC_SECRET="your_hmac_secret_here"
QR_REFRESH_INTERVAL_SECONDS=10
QR_CLOCK_SKEW_TOLERANCE_SECONDS=2

DEFAULT_GEOFENCE_RADIUS_M=300

CAMPUS_LATITUDE="11.08435833"
CAMPUS_LONGITUDE="76.99753056"

QR_SIGNING_SECRET="your_qr_signing_secret_here"
QR_EXPIRY_SECONDS=10
MAX_ATTENDANCE_DISTANCE_METERS=300
MAX_GPS_ACCURACY_METERS=50

SCAN_RATE_LIMIT_WINDOW_MS=60000
SCAN_RATE_LIMIT_MAX=10

FRONTEND_ORIGINS="http://localhost:5173"

# WhatsApp Configuration
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_PATH=.wwebjs_auth
WHATSAPP_RETRY_DELAY_MS=3000
WHATSAPP_MAX_RECONNECT_RETRIES=5
WHATSAPP_ADMIN_PHONE="919876543210"
