generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Faculty {
  id           String              @id @default(uuid())
  name         String
  email        String              @unique
  passwordHash String
  createdAt    DateTime            @default(now())
  sessions            AttendanceSession[]
  timetableAllocations TimetableAllocation[]
  substitutionsAsSubstitute TimetableSubstitution[]

  @@map("faculty")
}

model Admin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin")
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String   @unique
  otpHash   String   @map("otp_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_reset")
}

model Student {
  id           String             @id @default(uuid())
  name         String
  rollNo       String             @unique @map("roll_no")
  batchId      String             @map("batch_id")
  email        String             @unique
  passwordHash String
  deviceId     String?            @map("device_id")
  phone        String?            // WhatsApp number (e.g. "919876543210")
  parentPhone  String?            @map("parent_phone") // Parent's WhatsApp number
  trustScore   Int                @default(100) @map("trust_score")
  createdAt    DateTime           @default(now())
  records      AttendanceRecord[]
  whatsappLogs WhatsAppMessageLog[]
  leaveRequests LeaveRequest[]
  batch        Batch              @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("student")
}

model Batch {
  id       String              @id @default(uuid())
  name     String              @unique
  sessions AttendanceSession[]
  students Student[]
  timetableAllocations TimetableAllocation[]

  @@map("batch")
}

model Subject {
  id       String              @id @default(uuid())
  name     String
  code     String              @unique
  sessions AttendanceSession[]
  timetableAllocations TimetableAllocation[]

  @@map("subject")
}

model Room {
  id                 String              @id @default(uuid())
  name               String              @unique
  latitude           Float
  longitude          Float
  geofenceRadiusM    Int                 @default(800) @map("geofence_radius_m")
  wifiBssidWhitelist String[]            @map("wifi_bssid_whitelist")
  sessions           AttendanceSession[]
  timetableAllocations TimetableAllocation[]

  @@map("room")
}

model AttendanceSession {
  sessionId          String                @id @default(uuid()) @map("session_id")
  facultyId          String                @map("faculty_id")
  subjectId          String                @map("subject_id")
  roomId             String                @map("room_id")
  batchId            String                @map("batch_id")
  status             SessionStatus         @default(ACTIVE)
  startedAt          DateTime              @default(now()) @map("started_at")
  endedAt            DateTime?             @map("ended_at")
  currentQrTokenHash String?               @map("current_qr_token_hash")
  currentQrExpiry    DateTime?             @map("current_qr_expiry")
  createdAt          DateTime              @default(now()) @map("created_at")
  qrHistory          AttendanceQrHistory[]
  records            AttendanceRecord[]
  batch              Batch                 @relation(fields: [batchId], references: [id], onDelete: Cascade)
  faculty            Faculty               @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  room               Room                  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  subject            Subject               @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("attendance_session")
}

model AttendanceQrHistory {
  id              String            @id @default(uuid())
  sessionId       String            @map("session_id")
  tokenHash       String            @unique @map("token_hash")
  nonce           String
  generatedAt     DateTime          @default(now()) @map("generated_at")
  expiresAt       DateTime          @map("expires_at")
  isExpired       Boolean           @default(false) @map("is_expired")
  revoked         Boolean           @default(false)
  usedAt          DateTime?         @map("used_at")
  usedByStudentId String?           @map("used_by_student_id")
  session         AttendanceSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId, expiresAt])
  @@map("attendance_qr_history")
}

model AttendanceRecord {
  id                         String            @id @default(uuid())
  studentId                  String            @map("student_id")
  sessionId                  String            @map("session_id")
  scanTime                   DateTime          @default(now()) @map("scan_time")
  gpsLat                     Float             @map("gps_lat")
  gpsLng                     Float             @map("gps_lng")
  gpsAccuracy                Float?            @map("gps_accuracy")
  distanceFromCampus         Float?            @map("distance_from_campus")
  locationVerified           Boolean           @default(false) @map("location_verified")
  locationVerificationStatus String?           @map("location_verification_status")
  locationVerifiedAt         DateTime?         @map("location_verified_at")
  isSuspicious               Boolean           @default(false) @map("is_suspicious")
  flagReason                 String?           @map("flag_reason")
  status                     AttendanceStatus  @default(PRESENT)
  deviceId                   String            @map("device_id")
  createdAt                  DateTime          @default(now()) @map("created_at")
  session                    AttendanceSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  student                    Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, sessionId], name: "uq_student_session")
  @@index([sessionId])
  @@map("attendance_record")
}

model AuditLog {
  id         String    @id @default(uuid())
  actorId    String?   @map("actor_id")
  actorType  ActorType @map("actor_type")
  action     String
  success    Boolean   @default(true)
  reasonCode String?   @map("reason_code")
  sessionId  String?   @map("session_id")
  ip         String?
  userAgent  String?   @map("user_agent")
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([sessionId])
  @@map("audit_log")
}

enum SessionStatus {
  ACTIVE
  PAUSED
  ENDED
  EXPIRED
}

enum AttendanceStatus {
  PRESENT
  REJECTED_DUPLICATE
  REJECTED_EXPIRED
  REJECTED_GEOFENCE
  REJECTED_INVALID_SIGNATURE
}

enum ActorType {
  ADMIN
  FACULTY
  STUDENT
  SYSTEM
}

model AcademicMentorList {
  sNo            Int    @id @map("s_no")
  rollNo         String @map("roll_no")
  regNo          String @map("reg_no")
  name           String
  academicMentor String @map("academic_mentor")
  section        String?

  @@map("academic_mentor_list")
}

model WhatsAppMessageLog {
  id           String   @id @default(uuid())
  studentId    String   @map("student_id")
  phone        String
  messageBody  String   @map("message_body")
  status       String   // SENT | FAILED | RETRY_FAILED
  errorMessage String?  @map("error_message")
  attendanceId String?  @map("attendance_id")
  messageType  String   @default("ATTENDANCE") @map("message_type") // ATTENDANCE | MANUAL | PARENT
  createdAt    DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@index([status])
  @@map("whatsapp_message_log")
}

model TimetableAllocation {
  id        String   @id @default(uuid())
  facultyId String   @map("faculty_id")
  subjectId String   @map("subject_id")
  roomId    String   @map("room_id")
  batchId   String   @map("batch_id")
  dayOfWeek Int      @map("day_of_week") // 1=Mon, 5=Fri
  startTime String   @map("start_time") // HH:mm
  endTime   String   @map("end_time") // HH:mm
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  faculty Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  room    Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  batch   Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  substitutions TimetableSubstitution[]

  @@map("timetable_allocation")
}

model TimetableSubstitution {
  id                   String   @id @default(uuid())
  originalAllocationId String   @map("original_allocation_id")
  substituteFacultyId  String   @map("substitute_faculty_id")
  targetDate           DateTime @map("target_date") @db.Date
  createdAt            DateTime @default(now()) @map("created_at")

  originalAllocation TimetableAllocation @relation(fields: [originalAllocationId], references: [id], onDelete: Cascade)
  substituteFaculty  Faculty             @relation(fields: [substituteFacultyId], references: [id], onDelete: Cascade)

  @@unique([originalAllocationId, targetDate])
  @@map("timetable_substitution")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  LEAVE
  ON_DUTY
}

model LeaveRequest {
  id           String      @id @default(uuid())
  studentId    String      @map("student_id")
  type         LeaveType
  fromDate     DateTime    @map("from_date")
  toDate       DateTime    @map("to_date")
  reason       String
  status       LeaveStatus @default(PENDING)
  reviewNote   String?     @map("review_note")
  reviewedBy   String?     @map("reviewed_by")
  reviewedAt   DateTime?   @map("reviewed_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("leave_request")
}
