generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Faculty {
  id           String              @id @default(uuid())
  name         String
  email        String              @unique
  passwordHash String
  createdAt    DateTime            @default(now())
  sessions     AttendanceSession[]

  @@map("faculty")
}

model Student {
  id           String             @id @default(uuid())
  name         String
  rollNo       String             @unique @map("roll_no")
  batchId      String             @map("batch_id")
  email        String             @unique
  passwordHash String
  deviceId     String?            @map("device_id")
  createdAt    DateTime           @default(now())
  records      AttendanceRecord[]
  batch        Batch              @relation(fields: [batchId], references: [id])

  @@map("student")
}

model Batch {
  id       String              @id @default(uuid())
  name     String              @unique
  sessions AttendanceSession[]
  students Student[]

  @@map("batch")
}

model Subject {
  id       String              @id @default(uuid())
  name     String
  code     String              @unique
  sessions AttendanceSession[]

  @@map("subject")
}

model Room {
  id                 String              @id @default(uuid())
  name               String              @unique
  latitude           Float
  longitude          Float
  geofenceRadiusM    Int                 @default(120) @map("geofence_radius_m")
  wifiBssidWhitelist String[]            @map("wifi_bssid_whitelist")
  sessions           AttendanceSession[]

  @@map("room")
}

model AttendanceSession {
  sessionId          String                @id @default(uuid()) @map("session_id")
  facultyId          String                @map("faculty_id")
  subjectId          String                @map("subject_id")
  roomId             String                @map("room_id")
  batchId            String                @map("batch_id")
  status             SessionStatus         @default(ACTIVE)
  startedAt          DateTime              @default(now()) @map("started_at")
  endedAt            DateTime?             @map("ended_at")
  currentQrTokenHash String?               @map("current_qr_token_hash")
  currentQrExpiry    DateTime?             @map("current_qr_expiry")
  createdAt          DateTime              @default(now()) @map("created_at")
  qrHistory          AttendanceQrHistory[]
  records            AttendanceRecord[]
  batch              Batch                 @relation(fields: [batchId], references: [id])
  faculty            Faculty               @relation(fields: [facultyId], references: [id])
  room               Room                  @relation(fields: [roomId], references: [id])
  subject            Subject               @relation(fields: [subjectId], references: [id])

  @@index([status])
  @@map("attendance_session")
}

model AttendanceQrHistory {
  id              String            @id @default(uuid())
  sessionId       String            @map("session_id")
  tokenHash       String            @unique @map("token_hash")
  nonce           String
  generatedAt     DateTime          @default(now()) @map("generated_at")
  expiresAt       DateTime          @map("expires_at")
  isExpired       Boolean           @default(false) @map("is_expired")
  revoked         Boolean           @default(false)
  usedAt          DateTime?         @map("used_at")
  usedByStudentId String?           @map("used_by_student_id")
  session         AttendanceSession @relation(fields: [sessionId], references: [sessionId])

  @@index([sessionId, expiresAt])
  @@map("attendance_qr_history")
}

model AttendanceRecord {
  id                         String            @id @default(uuid())
  studentId                  String            @map("student_id")
  sessionId                  String            @map("session_id")
  scanTime                   DateTime          @default(now()) @map("scan_time")
  gpsLat                     Float             @map("gps_lat")
  gpsLng                     Float             @map("gps_lng")
  gpsAccuracy                Float?            @map("gps_accuracy")
  distanceFromCampus         Float?            @map("distance_from_campus")
  locationVerified           Boolean           @default(false) @map("location_verified")
  locationVerificationStatus String?           @map("location_verification_status")
  locationVerifiedAt         DateTime?         @map("location_verified_at")
  status                     AttendanceStatus  @default(PRESENT)
  deviceId                   String            @map("device_id")
  createdAt                  DateTime          @default(now()) @map("created_at")
  session                    AttendanceSession @relation(fields: [sessionId], references: [sessionId])
  student                    Student           @relation(fields: [studentId], references: [id])

  @@unique([studentId, sessionId], name: "uq_student_session")
  @@index([sessionId])
  @@map("attendance_record")
}

model AuditLog {
  id         String    @id @default(uuid())
  actorId    String?   @map("actor_id")
  actorType  ActorType @map("actor_type")
  action     String
  success    Boolean   @default(true)
  reasonCode String?   @map("reason_code")
  sessionId  String?   @map("session_id")
  ip         String?
  userAgent  String?   @map("user_agent")
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([sessionId])
  @@map("audit_log")
}

enum SessionStatus {
  ACTIVE
  ENDED
  EXPIRED
}

enum AttendanceStatus {
  PRESENT
  REJECTED_DUPLICATE
  REJECTED_EXPIRED
  REJECTED_GEOFENCE
  REJECTED_INVALID_SIGNATURE
}

enum ActorType {
  FACULTY
  STUDENT
  SYSTEM
}
